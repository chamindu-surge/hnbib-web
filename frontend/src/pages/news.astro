---
import InnerLayout from '../layouts/InnerLayout.astro';

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;
const STRAPI_TOKEN = import.meta.env.STRAPI_TOKEN;
let articles: any[] = [];
try {
  const headers: Record<string, string> = {};
  if (STRAPI_TOKEN) headers['Authorization'] = `Bearer ${STRAPI_TOKEN}`;
  const res = await fetch(
    `${STRAPI_URL}/api/articles?populate=*&sort=publishedAt:desc&pagination[limit]=6`,
    { headers }
  );
  if (res.ok) {
    const json = await res.json();
    articles = json.data || [];
  }
} catch {}

function fmtDate(iso: string) {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
function attr(a: any, key: string, fallback = '') {
  return a?.attributes?.[key] ?? fallback;
}
const hasArticles = articles.length > 0;
---

<InnerLayout title="News & Insights — HNB Investment Bank" active="news">
  <style is:global>
    /* ── Featured / Latest ───────────────────────── */
    .news-a-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .news-feat { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .news-feat-img { background: var(--frame); min-height: 280px; display: flex; align-items: center; justify-content: center; }
    .news-feat-img-placeholder { width: 80px; height: 80px; opacity: 0.3; }
    .news-feat-body { padding: 2.5rem; display: flex; flex-direction: column; justify-content: space-between; }
    .news-feat-body .news-meta { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1rem; }
    .news-cat { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); background: oklch(0.43 0.150 248 / 0.08); border: 1px solid oklch(0.43 0.150 248 / 0.15); border-radius: 4px; padding: 0.2rem 0.6rem; }
    .news-date { font-size: 0.78rem; color: var(--muted); }
    .news-feat-body h2 { font-size: 1.35rem; font-weight: 800; color: var(--ink); margin-bottom: 0.875rem; line-height: 1.3; }
    .news-feat-body p { font-size: 0.875rem; color: var(--ink-2); line-height: 1.7; margin-bottom: 1.5rem; flex: 1; }
    .news-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; }
    .news-card .news-meta { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.875rem; }
    .news-card h3 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; line-height: 1.4; }
    .news-card p { font-size: 0.83rem; color: var(--ink-2); line-height: 1.65; flex: 1; margin-bottom: 1rem; }
    .news-read-more { font-size: 0.8rem; font-weight: 700; color: var(--primary); text-decoration: none; }
    .news-read-more:hover { text-decoration: underline; }
    /* B — editorial */
    .news-b-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 2.5rem; align-items: start; }
    .news-b-main { display: flex; flex-direction: column; gap: 1.5rem; }
    .news-b-article { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.75rem; display: grid; grid-template-columns: 120px 1fr; gap: 1.25rem; align-items: start; }
    .news-b-img { background: var(--frame); border-radius: calc(var(--radius) - 2px); height: 90px; }
    .news-b-article .news-meta { margin-bottom: 0.5rem; display: flex; gap: 0.625rem; align-items: center; }
    .news-b-article h3 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 0.375rem; line-height: 1.35; }
    .news-b-article p { font-size: 0.82rem; color: var(--ink-2); line-height: 1.6; margin: 0; }
    .news-b-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
    .sidebar-section h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.75rem; border-bottom: 2px solid var(--primary); padding-bottom: 0.625rem; }
    .sidebar-item { display: flex; gap: 0.625rem; align-items: flex-start; padding: 0.625rem 0; border-bottom: 1px solid var(--line); }
    .sidebar-item:last-child { border-bottom: none; }
    .sidebar-item-date { font-size: 0.72rem; color: var(--muted); white-space: nowrap; margin-top: 0.125rem; }
    .sidebar-item h5 { font-size: 0.82rem; font-weight: 600; color: var(--ink); line-height: 1.4; }
    /* C — three-column */
    .news-c-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .news-c-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; }
    .news-c-img { background: var(--frame); height: 160px; }
    .news-c-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
    .news-c-body .news-meta { margin-bottom: 0.75rem; display: flex; gap: 0.625rem; align-items: center; }
    .news-c-body h3 { font-size: 0.95rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; line-height: 1.4; }
    .news-c-body p { font-size: 0.8rem; color: var(--ink-2); line-height: 1.65; flex: 1; margin-bottom: 0.875rem; }
    /* ── Research & Insights ─────────────────────── */
    .research-grid-news { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .research-card-news { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.5rem; }
    .research-card-news .rc-type { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-2); margin-bottom: 0.625rem; }
    .research-card-news h4 { font-size: 0.95rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; line-height: 1.4; }
    .research-card-news p { font-size: 0.82rem; color: var(--ink-2); line-height: 1.6; margin-bottom: 1rem; }
    .research-card-news .rc-meta { display: flex; gap: 0.75rem; font-size: 0.75rem; color: var(--muted); }
    .res-b-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start; }
    .res-featured { background: var(--card); border: 1px solid var(--line); border-top: 3px solid var(--accent); border-radius: var(--radius); padding: 2rem; }
    .res-featured .rc-type { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-2); margin-bottom: 0.625rem; }
    .res-featured h3 { font-size: 1.2rem; font-weight: 800; color: var(--ink); margin-bottom: 0.875rem; }
    .res-featured p { font-size: 0.875rem; color: var(--ink-2); line-height: 1.7; margin-bottom: 1rem; }
    .res-featured .rc-meta { font-size: 0.78rem; color: var(--muted); margin-bottom: 1.25rem; }
    .res-list { display: flex; flex-direction: column; gap: 0; }
    .res-list-item { padding: 0.875rem; border-bottom: 1px solid var(--line); }
    .res-list-item:last-child { border-bottom: none; }
    .res-list-item h5 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.25rem; }
    .res-list-item .rli-meta { font-size: 0.75rem; color: var(--muted); }
    /* ── Categories / Archive ────────────────────── */
    .archive-layout { display: grid; grid-template-columns: 240px 1fr; gap: 2.5rem; align-items: start; }
    .cat-nav { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .cat-nav h4 { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); padding: 1rem 1.25rem; border-bottom: 1px solid var(--line); }
    .cat-nav a { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--line); font-size: 0.875rem; color: var(--ink-2); text-decoration: none; }
    .cat-nav a:last-child { border-bottom: none; }
    .cat-nav a:hover, .cat-nav a.active { color: var(--primary); background: oklch(0.43 0.150 248 / 0.04); }
    .cat-nav a .cnt { font-size: 0.75rem; color: var(--muted); }
    .archive-list { display: flex; flex-direction: column; gap: 1rem; }
    .archive-item { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.25rem; display: flex; gap: 1rem; align-items: start; }
    .archive-item-date { background: var(--primary); color: #fff; border-radius: var(--radius); padding: 0.5rem 0.75rem; text-align: center; flex-shrink: 0; min-width: 52px; }
    .archive-item-date .day { font-size: 1.25rem; font-weight: 800; line-height: 1; }
    .archive-item-date .month { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.85; }
    .archive-item h4 { font-size: 0.925rem; font-weight: 700; color: var(--ink); margin-bottom: 0.25rem; }
    .archive-item p { font-size: 0.8rem; color: var(--ink-2); line-height: 1.6; margin: 0; }
    /* Filter bar shared */
    .filter-bar { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
    .filter-btn { font-size: 0.8rem; font-weight: 600; padding: 0.45rem 1rem; border: 1.5px solid var(--line); border-radius: 20px; background: var(--card); color: var(--ink-2); cursor: pointer; }
    .filter-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }
    .filtered-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .filtered-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.25rem; }
    .filtered-card .news-meta { margin-bottom: 0.625rem; display: flex; gap: 0.625rem; }
    .filtered-card h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); line-height: 1.4; }

    @media (max-width: 900px) {
      .news-feat { grid-template-columns: 1fr; }
      .news-a-grid, .news-b-layout, .res-b-layout, .archive-layout { grid-template-columns: 1fr; }
      .news-c-grid, .research-grid-news, .filtered-grid { grid-template-columns: 1fr 1fr; }
      .news-b-article { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .news-c-grid, .research-grid-news, .filtered-grid { grid-template-columns: 1fr; }
    }
  </style>

  <header class="page-header">
    <div class="page-header-inner">
      <span class="section-label">HNB Investment Bank</span>
      <h1>News &amp; Insights</h1>
      <p class="page-header-sub">Market analysis, transaction announcements, regulatory updates, and economic commentary from Sri Lanka's integrated investment bank.</p>
      <div class="page-header-meta">
        <span class="pill">Market Analysis</span>
        <span class="pill">Transaction News</span>
        <span class="pill-accent">Research Reports</span>
      </div>
    </div>
  </header>

  <div class="page-body">
    <div class="page-bg-map" aria-hidden="true"></div>

    <!-- ══ S1: LATEST NEWS ══ -->
    <section class="section-host" data-section-id="latest-news" data-section-label="Latest News">

      <!-- VARIANT A -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Latest News</span>
              <h2>Most Recent</h2>
            </div>
            {hasArticles ? (
              <div class="news-a-grid">
                {articles[0] && (
                  <div class="news-feat scroll-fade">
                    <div class="news-feat-img">
                      {attr(articles[0], 'cover')?.data?.attributes?.url
                        ? <img src={`${STRAPI_URL}${attr(articles[0], 'cover').data.attributes.url}`} alt="" style="width:100%;height:100%;object-fit:cover;" />
                        : <svg class="news-feat-img-placeholder" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="10" width="60" height="60" rx="4"/><path d="M20 50 L35 35 L45 45 L60 30"/></svg>
                      }
                    </div>
                    <div class="news-feat-body">
                      <div>
                        <div class="news-meta">
                          <span class="news-cat">{attr(articles[0], 'category', 'News')}</span>
                          <span class="news-date">{fmtDate(attr(articles[0], 'publishedAt'))}</span>
                        </div>
                        <h2>{attr(articles[0], 'title')}</h2>
                        <p>{attr(articles[0], 'excerpt', attr(articles[0], 'description'))}</p>
                      </div>
                      <a href="/news/" class="btn-ghost">Read Full Announcement →</a>
                    </div>
                  </div>
                )}
                {articles.slice(1, 4).map((a: any) => (
                  <div class="news-card">
                    <div class="news-meta"><span class="news-cat">{attr(a, 'category', 'News')}</span><span class="news-date">{fmtDate(attr(a, 'publishedAt'))}</span></div>
                    <h3>{attr(a, 'title')}</h3>
                    <p>{attr(a, 'excerpt', attr(a, 'description'))}</p>
                    <a href="/news/" class="news-read-more">Read more →</a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="news-a-grid">
                <div class="news-feat scroll-fade">
                  <div class="news-feat-img">
                    <svg class="news-feat-img-placeholder" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="10" width="60" height="60" rx="4"/><path d="M20 50 L35 35 L45 45 L60 30"/></svg>
                  </div>
                  <div class="news-feat-body">
                    <div>
                      <div class="news-meta">
                        <span class="news-cat">Transaction</span>
                        <span class="news-date">22 May 2025</span>
                      </div>
                      <h2>HNB Investment Bank Advises Hayleys on LKR 7Bn Debenture Programme</h2>
                      <p>HNB Investment Bank Limited, acting as sole Arranger and Lead Manager, has successfully closed a LKR 7 billion rated debenture issuance for Hayleys PLC — the largest corporate bond in Sri Lanka's capital market in the 2024/25 financial year. The issue was oversubscribed by 1.4×, with strong participation from insurance funds and licensed finance companies.</p>
                    </div>
                    <a href="/news/" class="btn-ghost">Read Full Announcement →</a>
                  </div>
                </div>
                <div class="news-card">
                  <div class="news-meta"><span class="news-cat">Market</span><span class="news-date">20 May 2025</span></div>
                  <h3>ASPI Breaks 22,500 — First Time Since January 2022</h3>
                  <p>The All Share Price Index (ASPI) closed at 22,622 on Monday, breaching the 22,500 level for the first time since Sri Lanka's economic crisis. HNB Stockbrokers attributed the rally to improved macro confidence following the successful IMF third review.</p>
                  <a href="/news/" class="news-read-more">Read more →</a>
                </div>
                <div class="news-card">
                  <div class="news-meta"><span class="news-cat">Research</span><span class="news-date">18 May 2025</span></div>
                  <h3>Sri Lanka Fixed Income Outlook H2 2025: Rates to Ease Further</h3>
                  <p>HNB Investment Bank's Fixed Income Desk forecasts a further 50–75bps reduction in the CBSL policy corridor by end-2025. T-Bill yields expected to converge toward 9.00% on the 364-day tenor.</p>
                  <a href="/news/" class="news-read-more">Read more →</a>
                </div>
                <div class="news-card">
                  <div class="news-meta"><span class="news-cat">Company</span><span class="news-date">15 May 2025</span></div>
                  <h3>HNB Investment Bank Reports 24.7% Growth in Profit Before Tax for FY2025</h3>
                  <p>Full year results ending 31 March 2025 show profit before tax of LKR 2.1Bn, up 24.7% year-on-year. The Board has proposed a dividend of LKR 3.50 per share.</p>
                  <a href="/news/" class="news-read-more">Read more →</a>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- VARIANT B: Editorial magazine -->
      <div class="variant" data-variant="B" data-variant-label="Middle">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Latest News</span>
              <h2>What's Happening</h2>
            </div>
            <div class="news-b-layout">
              <div class="news-b-main">
                <div class="news-b-article">
                  <div class="news-b-img"></div>
                  <div>
                    <div class="news-meta"><span class="news-cat">Transaction</span><span class="news-date">22 May 2025</span></div>
                    <h3>HNB Investment Bank Advises Hayleys on LKR 7Bn Debenture</h3>
                    <p>Largest corporate bond of FY2024/25. Issue oversubscribed 1.4×. Rating: AA(lka) by Fitch.</p>
                    <a href="/news/" class="news-read-more" style="margin-top:0.625rem; display:inline-block;">Read full announcement →</a>
                  </div>
                </div>
                <div class="news-b-article">
                  <div class="news-b-img"></div>
                  <div>
                    <div class="news-meta"><span class="news-cat">Market</span><span class="news-date">20 May 2025</span></div>
                    <h3>ASPI Breaks 22,500 — Rally Broadens Across Sectors</h3>
                    <p>HNB Stockbrokers' market commentary on the CSE's best run in three years. Key drivers and sector analysis.</p>
                    <a href="/news/" class="news-read-more" style="margin-top:0.625rem; display:inline-block;">Read more →</a>
                  </div>
                </div>
                <div class="news-b-article">
                  <div class="news-b-img"></div>
                  <div>
                    <div class="news-meta"><span class="news-cat">Company</span><span class="news-date">15 May 2025</span></div>
                    <h3>FY2025 Results: Profit Before Tax LKR 2.1Bn, +24.7% YoY</h3>
                    <p>Audited full-year results and proposed dividend announcement for the year ended 31 March 2025.</p>
                    <a href="/news/" class="news-read-more" style="margin-top:0.625rem; display:inline-block;">Read more →</a>
                  </div>
                </div>
              </div>
              <div class="news-b-sidebar">
                <div class="sidebar-section">
                  <h4>Quick Reads</h4>
                  <div class="sidebar-item"><div class="sidebar-item-date">18 May</div><h5>Fixed Income Outlook H2 2025 — T-Bill rates to ease toward 9%</h5></div>
                  <div class="sidebar-item"><div class="sidebar-item-date">12 May</div><h5>LVL Energy Fund Q4 NAV: LKR 19.85 per share</h5></div>
                  <div class="sidebar-item"><div class="sidebar-item-date">05 May</div><h5>CSE Market Turnover Hits LKR 2.1Bn — 3-Year High</h5></div>
                  <div class="sidebar-item"><div class="sidebar-item-date">28 Apr</div><h5>Union Bank IPO — 300× Oversubscribed; Listing Date Confirmed</h5></div>
                </div>
                <div class="sidebar-section">
                  <h4>Categories</h4>
                  <div class="sidebar-item"><h5>Transactions &amp; Deals</h5></div>
                  <div class="sidebar-item"><h5>Market Commentary</h5></div>
                  <div class="sidebar-item"><h5>Research Reports</h5></div>
                  <div class="sidebar-item"><h5>Company News</h5></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT C: Three-column -->
      <div class="variant" data-variant="C" data-variant-label="Ambitious">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Latest News</span>
              <h2>Top Stories This Week</h2>
            </div>
            <div class="news-c-grid">
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Transaction</span><span class="news-date">22 May 2025</span></div>
                  <h3>Hayleys LKR 7Bn Debenture — HNB Investment Bank Sole Arranger</h3>
                  <p>Sri Lanka's largest corporate bond of FY2024/25. AA(lka) rated. 1.4× oversubscribed.</p>
                  <a href="/news/" class="news-read-more">Read announcement →</a>
                </div>
              </div>
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Market</span><span class="news-date">20 May 2025</span></div>
                  <h3>ASPI at 22,622 — Breaking Down the Three-Year High</h3>
                  <p>What's driving the CSE rally, which sectors are leading, and where HNB Stockbrokers sees the index going.</p>
                  <a href="/news/" class="news-read-more">Read analysis →</a>
                </div>
              </div>
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Research</span><span class="news-date">18 May 2025</span></div>
                  <h3>Fixed Income Outlook H2 2025: A Soft Landing for Sri Lankan Rates</h3>
                  <p>Our fixed income team's full-year view on T-Bill and T-Bond yields, policy rate trajectory, and investment positioning.</p>
                  <a href="/news/" class="news-read-more">Download report →</a>
                </div>
              </div>
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Company</span><span class="news-date">15 May 2025</span></div>
                  <h3>FY2025 Full-Year Results: Three Consecutive Years of Profit Growth</h3>
                  <p>PBT LKR 2.1Bn (+24.7%). ROE 18.4%. Proposed dividend LKR 3.50 per share.</p>
                  <a href="/news/" class="news-read-more">Read results →</a>
                </div>
              </div>
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Company</span><span class="news-date">12 May 2025</span></div>
                  <h3>LVL Energy Fund Q4 NAV Update: LKR 19.85 per Share</h3>
                  <p>Quarterly NAV disclosure per CSE Listing Rules. SL Energies' 45MW solar facility remains the anchor position.</p>
                  <a href="/news/" class="news-read-more">Read update →</a>
                </div>
              </div>
              <div class="news-c-card">
                <div class="news-c-img"></div>
                <div class="news-c-body">
                  <div class="news-meta"><span class="news-cat">Market</span><span class="news-date">05 May 2025</span></div>
                  <h3>CSE Daily Turnover Hits LKR 2.15Bn — Best Liquidity Since 2022</h3>
                  <p>HNB Stockbrokers processed the highest single-day trade volume in three years. Retail and institutional participation both contributed.</p>
                  <a href="/news/" class="news-read-more">Read commentary →</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>

    <!-- ══ S2: RESEARCH & INSIGHTS ══ -->
    <section class="section-host" data-section-id="research-insights" data-section-label="Research &amp; Insights">

      <!-- VARIANT A -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade" style="background:var(--bg-2);">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Research &amp; Insights</span>
              <h2>Analyst Publications</h2>
              <p>Proprietary research from HNB Stockbrokers Equity Research and the HNB Investment Bank Fixed Income Desk.</p>
