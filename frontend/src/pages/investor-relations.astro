---
import InnerLayout from '../layouts/InnerLayout.astro';
---

<InnerLayout title="Investor Relations — HNB Investment Bank" active="investor-relations">
  <style is:global>
    /* ── Financial Highlights ──────────────────── */
    .fh-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
    .fh-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.5rem; text-align: center; }
    .fh-val { font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 0.25rem; }
    .fh-label { font-size: 0.78rem; color: var(--muted); margin-bottom: 0.375rem; }
    .fh-change { font-size: 0.8rem; font-weight: 600; }
    .fh-change.up { color: oklch(0.45 0.14 145); }
    .fh-change.dn { color: oklch(0.45 0.18 25); }
    .fh-b-wrap { display: grid; grid-template-columns: 2fr 1fr; gap: 2.5rem; align-items: start; }
    .fin-table { width: 100%; border-collapse: collapse; }
    .fin-table th { font-size: 0.78rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; text-align: left; padding: 0.625rem 0.875rem; background: var(--bg-2); border-bottom: 2px solid var(--line); }
    .fin-table th:not(:first-child) { text-align: right; }
    .fin-table td { padding: 0.75rem 0.875rem; border-bottom: 1px solid var(--line); font-size: 0.875rem; color: var(--ink-2); }
    .fin-table td:not(:first-child) { text-align: right; }
    .fin-table td.val-pos { font-weight: 700; color: oklch(0.45 0.14 145); }
    .fin-table td.val-main { font-weight: 700; color: var(--ink); }
    .fin-table tr:last-child td { border-bottom: none; font-weight: 700; }
    .ir-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
    .ir-s-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.25rem; }
    .ir-s-card h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.75rem; border-bottom: 1px solid var(--line); padding-bottom: 0.625rem; }
    .ir-s-row { display: flex; justify-content: space-between; padding: 0.375rem 0; border-bottom: 1px solid var(--line); }
    .ir-s-row:last-child { border-bottom: none; }
    .ir-s-label { font-size: 0.8rem; color: var(--ink-2); }
    .ir-s-val { font-size: 0.875rem; font-weight: 700; color: var(--ink); }
    .fh-c-inner { background: var(--primary); border-radius: var(--radius); padding: 3rem; color: #fff; }
    .fh-c-inner .section-label { color: oklch(0.65 0.165 140); }
    .fh-c-inner h2 { color: #fff; margin: 0.75rem 0 1rem; }
    .fh-c-inner p { color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 1rem; }
    .fh-c-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.2); }
    .fh-c-kpi .kval { font-size: 1.75rem; font-weight: 800; color: #fff; }
    .fh-c-kpi .klbl { font-size: 0.75rem; color: rgba(255,255,255,0.65); margin-top: 0.25rem; }
    .btn-primary-inv-ir { display: inline-flex; align-items: center; gap: 0.5rem; background: #fff; color: var(--primary); border: none; border-radius: var(--radius); padding: 0.75rem 1.5rem; font-size: 0.875rem; font-weight: 700; cursor: pointer; text-decoration: none; }
    .btn-ghost-inv-ir { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.45); border-radius: var(--radius); padding: 0.75rem 1.5rem; font-size: 0.875rem; font-weight: 700; cursor: pointer; text-decoration: none; }
    /* ── Documents & Disclosures ──────────────── */
    .doc-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .doc-category h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.875rem; padding-bottom: 0.625rem; border-bottom: 2px solid var(--primary); }
    .doc-list { display: flex; flex-direction: column; gap: 0.625rem; }
    .doc-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); text-decoration: none; transition: border-color 0.15s; }
    .doc-item:hover { border-color: var(--primary); }
    .doc-icon { width: 32px; height: 32px; border-radius: 6px; background: oklch(0.43 0.150 248 / 0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .doc-icon svg { width: 16px; height: 16px; stroke: var(--primary); fill: none; }
    .doc-info h5 { font-size: 0.82rem; font-weight: 700; color: var(--ink); margin-bottom: 0.1rem; }
    .doc-info span { font-size: 0.72rem; color: var(--muted); }
    .doc-b-wrap { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start; }
    .doc-table { width: 100%; border-collapse: collapse; }
    .doc-table th { font-size: 0.78rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; text-align: left; padding: 0.625rem 0.875rem; background: var(--bg-2); border-bottom: 2px solid var(--line); }
    .doc-table td { padding: 0.75rem 0.875rem; border-bottom: 1px solid var(--line); font-size: 0.875rem; color: var(--ink-2); }
    .doc-table tr:last-child td { border-bottom: none; }
    .doc-table td a { color: var(--primary); text-decoration: none; font-weight: 600; }
    .doc-table td a:hover { text-decoration: underline; }
    .doc-c-inner { background: var(--bg-2); border-radius: var(--radius); padding: 2.5rem; }
    .doc-c-year { margin-bottom: 2rem; }
    .doc-c-year h4 { font-size: 0.875rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.875rem; }
    .doc-c-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); margin-bottom: 0.5rem; }
    .doc-c-row-info { display: flex; align-items: center; gap: 0.75rem; }
    .doc-c-row-info h5 { font-size: 0.875rem; font-weight: 600; color: var(--ink); margin-bottom: 0.1rem; }
    .doc-c-row-info span { font-size: 0.72rem; color: var(--muted); }
    .doc-c-badge { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.2rem 0.6rem; border-radius: 4px; background: var(--bg-2); color: var(--muted); border: 1px solid var(--line); }
    .doc-c-badge.annual { background: oklch(0.43 0.150 248 / 0.1); color: var(--primary); border-color: oklch(0.43 0.150 248 / 0.2); }
    /* ── Governance ──────────────────────────── */
    .gov-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
    .board-list { display: flex; flex-direction: column; gap: 0.875rem; }
    .board-member { display: flex; gap: 1rem; align-items: center; background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1rem 1.25rem; }
    .bm-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--frame); display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 800; color: var(--primary); flex-shrink: 0; }
    .bm-info h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.125rem; }
    .bm-info p { font-size: 0.78rem; color: var(--muted); margin: 0; }
    .bm-badge { margin-left: auto; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 4px; white-space: nowrap; }
    .bm-badge.exec { background: oklch(0.43 0.150 248 / 0.1); color: var(--primary); border: 1px solid oklch(0.43 0.150 248 / 0.2); }
    .bm-badge.nex { background: oklch(0.65 0.165 140 / 0.1); color: var(--accent-2); border: 1px solid oklch(0.65 0.165 140 / 0.2); }
    .gov-policies { display: flex; flex-direction: column; gap: 0.875rem; }
    .gov-policy { background: var(--card); border: 1px solid var(--line); border-left: 3px solid var(--accent); border-radius: var(--radius); padding: 1.125rem; }
    .gov-policy h5 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.25rem; }
    .gov-policy p { font-size: 0.8rem; color: var(--ink-2); line-height: 1.55; margin: 0; }
    .gov-c-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .gov-c-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.75rem; }
    .gov-c-card h4 { font-size: 0.95rem; font-weight: 700; color: var(--ink); margin-bottom: 0.875rem; }
    .gov-c-card ul { list-style: none; padding: 0; }
    .gov-c-card ul li { font-size: 0.82rem; color: var(--ink-2); padding: 0.3rem 0; border-bottom: 1px solid var(--line); display: flex; gap: 0.5rem; }
    .gov-c-card ul li::before { content: '→'; color: var(--primary); flex-shrink: 0; }
    .gov-c-card ul li:last-child { border-bottom: none; }

    @media (max-width: 900px) {
      .fh-grid-4 { grid-template-columns: repeat(2, 1fr); }
      .fh-b-wrap, .doc-b-wrap, .gov-grid { grid-template-columns: 1fr; }
      .fh-c-kpis { grid-template-columns: repeat(2, 1fr); }
      .doc-grid-3, .gov-c-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .fh-grid-4, .doc-grid-3, .gov-c-grid, .fh-c-kpis { grid-template-columns: 1fr; }
    }
  </style>

  <header class="page-header">
    <div class="page-header-inner">
      <span class="section-label">Company</span>
      <h1>Investor Relations</h1>
      <p class="page-header-sub">Financial results, regulatory disclosures, board governance, and shareholder communications for HNB Investment Bank Limited and its listed subsidiaries.</p>
      <div class="page-header-meta">
        <span class="pill">LVL.N0000 — CSE Listed</span>
        <span class="pill">Regulated by SEC of Sri Lanka</span>
        <span class="pill-accent">FY2025 Results Available</span>
      </div>
    </div>
  </header>

  <div class="page-body">
    <div class="page-bg-map" aria-hidden="true"></div>

    <!-- ══ S1: FINANCIAL HIGHLIGHTS ══ -->
    <section class="section-host" data-section-id="financial-highlights" data-section-label="Financial Highlights">

      <!-- VARIANT A: 4-col KPI cards -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Financial Highlights</span>
              <h2>FY2025 Performance Summary</h2>
              <p>Results for the financial year ending 31 March 2025. Audited by KPMG Sri Lanka.</p>
            </div>
            <div class="fh-grid-4">
              <div class="fh-card"><div class="fh-val" data-count="8.4" data-suffix="Bn">—</div><div class="fh-label">Total Revenue (LKR)</div><div class="fh-change up">▲ 18.3% YoY</div></div>
              <div class="fh-card"><div class="fh-val" data-count="2.1" data-suffix="Bn">—</div><div class="fh-label">Profit Before Tax (LKR)</div><div class="fh-change up">▲ 24.7% YoY</div></div>
              <div class="fh-card"><div class="fh-val" data-count="1.56" data-suffix="Bn">—</div><div class="fh-label">Profit After Tax (LKR)</div><div class="fh-change up">▲ 22.1% YoY</div></div>
              <div class="fh-card"><div class="fh-val" data-count="18.4" data-suffix="%">—</div><div class="fh-label">Return on Equity</div><div class="fh-change up">▲ 310bps YoY</div></div>
            </div>
            <div class="fh-grid-4" style="margin-top:1.5rem;">
              <div class="fh-card"><div class="fh-val" data-count="11.2" data-suffix="Bn">—</div><div class="fh-label">Total Assets (LKR)</div><div class="fh-change up">▲ 12.6% YoY</div></div>
              <div class="fh-card"><div class="fh-val" data-count="7.8" data-suffix="Bn">—</div><div class="fh-label">AUM (Total, LKR)</div><div class="fh-change up">▲ 15.2% YoY</div></div>
              <div class="fh-card"><div class="fh-val" data-count="47" data-suffix="+">—</div><div class="fh-label">Capital Markets Transactions</div><div class="fh-change up">▲ 8 vs FY2024</div></div>
              <div class="fh-card"><div class="fh-val">LKR 3.50</div><div class="fh-label">Dividend per Share (Proposed)</div><div class="fh-change up">▲ LKR 0.50 vs FY2024</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT B: 5-year table + sidebar -->
      <div class="variant" data-variant="B" data-variant-label="Middle">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Financial Highlights</span>
              <h2>5-Year Financial Summary</h2>
              <p>Audited financials. All figures in LKR Millions unless stated.</p>
            </div>
            <div class="fh-b-wrap">
              <div>
                <table class="fin-table">
                  <thead><tr><th>Metric</th><th>FY2025</th><th>FY2024</th><th>FY2023</th><th>FY2022</th></tr></thead>
                  <tbody>
                    <tr><td>Total Revenue</td><td class="val-main">8,412</td><td>7,112</td><td>5,820</td><td>3,940</td></tr>
                    <tr><td>Operating Expenses</td><td>3,680</td><td>3,210</td><td>2,890</td><td>2,320</td></tr>
                    <tr><td>Profit Before Tax</td><td class="val-main">2,148</td><td>1,722</td><td>1,104</td><td>422</td></tr>
                    <tr><td>Profit After Tax</td><td class="val-main">1,564</td><td>1,281</td><td>792</td><td>284</td></tr>
                    <tr><td>Total Assets</td><td class="val-main">11,240</td><td>9,980</td><td>8,650</td><td>7,120</td></tr>
                    <tr><td>Total Equity</td><td class="val-main">5,860</td><td>4,920</td><td>3,940</td><td>3,280</td></tr>
                    <tr><td>Return on Equity (%)</td><td class="val-pos">18.4%</td><td>15.3%</td><td>11.8%</td><td>6.2%</td></tr>
                    <tr><td>Cost-to-Income Ratio (%)</td><td class="val-pos">43.7%</td><td>45.1%</td><td>49.7%</td><td>58.9%</td></tr>
                    <tr><td>Dividend per Share (LKR)</td><td class="val-main">3.50*</td><td>3.00</td><td>1.50</td><td>—</td></tr>
                  </tbody>
                </table>
                <div style="font-size:0.72rem; color:var(--muted); margin-top:0.625rem; font-style:italic;">*Proposed. Subject to AGM approval. FY = year ending 31 March.</div>
              </div>
              <div class="ir-sidebar">
                <div class="ir-s-card">
                  <h4>Share Information</h4>
                  <div class="ir-s-row"><span class="ir-s-label">Listed Entity</span><span class="ir-s-val">LVL.N0000 (CSE)</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">Shares Outstanding</span><span class="ir-s-val">100,000,000</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">Last Price</span><span class="ir-s-val">LKR 17.40</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">Market Cap</span><span class="ir-s-val">LKR 1.74Bn</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">52W High / Low</span><span class="ir-s-val">19.20 / 12.80</span></div>
                </div>
                <div class="ir-s-card">
                  <h4>Key Dates FY2026</h4>
                  <div class="ir-s-row"><span class="ir-s-label">Q1 Results</span><span class="ir-s-val">Aug 2025</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">AGM</span><span class="ir-s-val">Sep 2025</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">H1 Results</span><span class="ir-s-val">Nov 2025</span></div>
                  <div class="ir-s-row"><span class="ir-s-label">Q3 Results</span><span class="ir-s-val">Feb 2026</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT C: Editorial on primary -->
      <div class="variant" data-variant="C" data-variant-label="Ambitious">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="fh-c-inner">
              <span class="section-label">Financial Highlights</span>
              <h2>FY2025: Three Years of Consecutive Profit Growth</h2>
              <p>HNB Investment Bank's FY2025 results reflect a business that has recovered from Sri Lanka's 2022 economic crisis faster than the broader capital market — and is now capitalising on structural tailwinds in fixed income, equity capital markets, and venture investing.</p>
              <div class="fh-c-kpis">
                <div class="fh-c-kpi"><div class="kval">LKR 8.4Bn</div><div class="klbl">Total Revenue</div></div>
                <div class="fh-c-kpi"><div class="kval">18.4%</div><div class="klbl">Return on Equity</div></div>
                <div class="fh-c-kpi"><div class="kval">LKR 7.8Bn</div><div class="klbl">Total AUM</div></div>
                <div class="fh-c-kpi"><div class="kval">43.7%</div><div class="klbl">Cost-to-Income</div></div>
              </div>
              <div style="display:flex; gap:1rem; margin-top:2rem; flex-wrap:wrap;">
                <a href="#documents" class="btn-primary-inv-ir">Download Annual Report</a>
                <a href="/contact-us/" class="btn-ghost-inv-ir">IR Contact</a>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>

    <!-- ══ S2: DOCUMENTS & DISCLOSURES ══ -->
    <section class="section-host" id="documents" data-section-id="documents" data-section-label="Documents &amp; Disclosures">

      <!-- VARIANT A: 3-col category cards -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade" style="background:var(--bg-2);">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Documents &amp; Disclosures</span>
              <h2>Financial Reports &amp; CSE Filings</h2>
            </div>
            <div class="doc-grid-3">
              <div class="doc-category">
                <h4>Annual Reports</h4>
                <div class="doc-list">
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div><div class="doc-info"><h5>Annual Report FY2025</h5><span>PDF · 8.4 MB · May 2025</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="doc-info"><h5>Annual Report FY2024</h5><span>PDF · 7.1 MB · May 2024</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="doc-info"><h5>Annual Report FY2023</h5><span>PDF · 6.5 MB · May 2023</span></div></a>
                </div>
              </div>
              <div class="doc-category">
                <h4>Interim Financial Statements</h4>
                <div class="doc-list">
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="doc-info"><h5>Q3 FY2026 (Dec 2024)</h5><span>PDF · 1.2 MB · Feb 2025</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="doc-info"><h5>H1 FY2026 (Sep 2024)</h5><span>PDF · 1.4 MB · Nov 2024</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="doc-info"><h5>Q1 FY2026 (Jun 2024)</h5><span>PDF · 1.1 MB · Aug 2024</span></div></a>
                </div>
              </div>
              <div class="doc-category">
                <h4>CSE Announcements</h4>
                <div class="doc-list">
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg></div><div class="doc-info"><h5>Dividend Announcement</h5><span>27 May 2025</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/></svg></div><div class="doc-info"><h5>Board Appointment</h5><span>15 Apr 2025</span></div></a>
                  <a class="doc-item" href="#"><div class="doc-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg></div><div class="doc-info"><h5>AGM Notice FY2025</h5><span>01 Apr 2025</span></div></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT B: Table + IR info -->
      <div class="variant" data-variant="B" data-variant-label="Middle">
        <div class="section-wrap scroll-fade" style="background:var(--bg-2);">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Documents &amp; Disclosures</span>
