---
import InnerLayout from '../layouts/InnerLayout.astro';
---
<InnerLayout
  title="HNB Stockbrokers — HNB Investment Bank"
  description="SEC registered stockbroker on the Colombo Stock Exchange. Online CSE trading, research-led advisory, and live market data. Open a CDS account in 24 hours."
  active="businesses"
>
  <style is:global>
    /* ── HNB Stockbrokers page-specific ── */
    .platform-a { background: var(--bg); }
    .plat-a-grid { display: grid; grid-template-columns: 1fr 360px; gap: 64px; align-items: start; }
    .plat-features { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .plat-feat { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; }
    .plat-icon { width: 44px; height: 44px; background: oklch(0.43 0.150 248 / 0.10); border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .plat-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
    .plat-body  { font-size: 14px; color: var(--ink-2); line-height: 1.6; }
    .plat-stat-panel { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); border-top: 3px solid var(--primary); padding: 28px; }
    .stat-panel-heading { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 20px; }
    .stat-row { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0; border-bottom: 1px solid var(--line); }
    .stat-row:last-child { border-bottom: none; }
    .stat-name { font-size: 13px; color: var(--ink-2); }
    .stat-val  { font-size: 16px; font-weight: 800; color: var(--ink); }
    .stat-chg  { font-size: 12px; font-weight: 700; margin-left: 6px; }
    .up { color: oklch(0.45 0.15 140); }
    .dn { color: oklch(0.50 0.15 25); }
    .plat-cta { margin-top: 24px; text-align: center; }

    .platform-b { background: var(--bg-2); }
    .plat-b-grid { display: grid; grid-template-columns: 1fr 400px; gap: 64px; align-items: start; }
    .feat-list { display: flex; flex-direction: column; gap: 0; }
    .feat-item { display: flex; align-items: flex-start; gap: 20px; padding: 22px 0; border-bottom: 1px solid var(--line); }
    .feat-item:first-child { padding-top: 0; }
    .feat-item:last-child  { border-bottom: none; padding-bottom: 0; }
    .feat-num   { font-size: 13px; font-weight: 800; color: var(--primary); min-width: 24px; padding-top: 3px; }
    .feat-title { font-size: 17px; font-weight: 700; margin-bottom: 4px; }
    .feat-desc  { font-size: 14px; color: var(--ink-2); line-height: 1.65; }
    .live-panel { background: var(--card); border: 1px solid var(--frame); border-radius: var(--radius); border-top: 3px solid var(--primary); padding: 28px; position: sticky; top: 80px; }
    .live-panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .live-panel-title { font-size: 13px; font-weight: 700; color: var(--ink); }
    .index-row { padding: 10px 0; border-bottom: 1px solid var(--line); }
    .index-row:last-of-type { border-bottom: none; }
    .ir-name { font-size: 12px; color: var(--ink-2); margin-bottom: 3px; }
    .ir-val  { font-size: 22px; font-weight: 800; color: var(--ink); line-height: 1; }
    .ir-chg  { font-size: 12px; font-weight: 700; margin-top: 2px; }
    .sparkline-wrap-b { margin-top: 16px; }
    .sparkline-svg-b  { width: 100%; height: 56px; }

    .platform-c { background: var(--primary); }
    .platform-c .section-label { color: oklch(1 0 0 / 0.55); }
    .platform-c h2 { color: oklch(1 0 0); }
    .platform-c p  { color: oklch(1 0 0 / 0.78); }
    .plat-c-top  { max-width: 600px; margin-bottom: 48px; }
    .plat-c-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
    .plat-kpi { padding: 0 24px 0 0; border-right: 1px solid oklch(1 0 0 / 0.15); }
    .plat-kpi:first-child { padding-left: 0; }
    .plat-kpi:last-child  { border-right: none; }
    .plat-kpi-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: oklch(1 0 0 / 0.55); margin-bottom: 6px; }
    .plat-kpi-val   { font-size: 32px; font-weight: 800; color: oklch(1 0 0); line-height: 1; }
    .plat-kpi-sub   { font-size: 12px; color: oklch(1 0 0 / 0.6); margin-top: 4px; }
    .plat-c-bar-chart { margin-top: 48px; }
    .plat-c-bar-head  { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .plat-c-bar-title { font-size: 13px; font-weight: 700; color: oklch(1 0 0 / 0.65); }
    .sector-bars { display: flex; flex-direction: column; gap: 12px; }
    .sector-bar-row { display: flex; align-items: center; gap: 16px; }
    .sbar-name  { font-size: 12px; color: oklch(1 0 0 / 0.7); min-width: 120px; }
    .sbar-track { flex: 1; height: 6px; background: oklch(1 0 0 / 0.12); border-radius: 3px; }
    .sbar-fill  { height: 100%; border-radius: 3px; background: oklch(1 0 0 / 0.72); }
    .sbar-val   { font-size: 12px; font-weight: 700; color: oklch(1 0 0 / 0.8); min-width: 60px; text-align: right; }
    .plat-c-cta { margin-top: 40px; display: flex; gap: 16px; flex-wrap: wrap; }
    .btn-primary-inv { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: oklch(1 0 0); color: var(--primary); font-weight: 700; font-size: 15px; border-radius: var(--radius); transition: transform 200ms var(--ease-out-quart), box-shadow 200ms var(--ease-out-quart); }
    .btn-primary-inv:hover { transform: translateY(-2px); box-shadow: 0 8px 24px oklch(0 0 0 / 0.18); }
    .btn-ghost-inv { display: inline-flex; align-items: center; gap: 8px; padding: 11px 23px; border: 1.5px solid oklch(1 0 0 / 0.55); color: oklch(1 0 0); font-weight: 700; font-size: 15px; border-radius: var(--radius); background: transparent; transition: border-color 200ms, background 200ms; }
    .btn-ghost-inv:hover { border-color: oklch(1 0 0); background: oklch(1 0 0 / 0.08); }

    .mdata-a { background: var(--bg-2); }
    .mdata-a-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
    .mdata-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; }
    .mdata-card-title { font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
    .mdata-row { display: flex; justify-content: space-between; align-items: baseline; padding: 10px 0; border-bottom: 1px solid var(--line); font-size: 14px; }
    .mdata-row:last-child { border-bottom: none; }
    .mdata-label { color: var(--ink-2); }
    .mdata-value { font-weight: 700; color: var(--ink); }
    .mdata-note  { font-size: 11px; color: var(--muted); margin-top: 12px; }

    .mdata-b { background: var(--bg); }
    .mdata-b-inner { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
    .sc-heading { font-size: 13px; font-weight: 700; color: var(--ink-2); margin-bottom: 20px; text-transform: uppercase; letter-spacing: 0.1em; }
    .sc-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--line); }
    .sc-row:last-child { border-bottom: none; }
    .sc-name { font-size: 14px; font-weight: 600; min-width: 140px; color: var(--ink); }
    .sc-bar-wrap { flex: 1; height: 8px; background: var(--bg-2); border-radius: 4px; overflow: hidden; }
    .sc-bar-fill { height: 100%; border-radius: 4px; background: var(--primary); }
    .sc-bar-fill.neg { background: oklch(0.55 0.12 25); }
    .sc-pct  { font-size: 13px; font-weight: 700; min-width: 60px; text-align: right; }
    .sc-pct.up { color: oklch(0.45 0.15 140); }
    .sc-pct.dn { color: oklch(0.50 0.15 25); }
    .vol-panel { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px; }
    .vol-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 16px; }
    .vol-row   { padding: 10px 0; border-bottom: 1px solid var(--line); }
    .vol-row:last-child { border-bottom: none; }
    .vol-name  { font-size: 13px; color: var(--ink-2); }
    .vol-val   { font-size: 16px; font-weight: 800; margin-top: 2px; }

    .mdata-c { background: var(--bg-2); }
    .kpi-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
    .kpi-tile-c { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px 24px; text-align: center; }
    .ktc-fig   { font-size: 36px; font-weight: 800; color: var(--primary); line-height: 1; }
    .ktc-label { font-size: 13px; color: var(--ink-2); margin-top: 8px; }
    .ktc-sub   { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .sparkline-row { display: flex; gap: 20px; }
    .sparkline-panel-c { flex: 1; background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px; }
    .sp-c-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 12px; }
    .sp-c-val   { font-size: 24px; font-weight: 800; margin-bottom: 12px; }
    .sparkline-svg-c { width: 100%; height: 48px; }

    .research-a { background: var(--bg); }
    .research-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .res-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; }
    .res-tag  { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; background: oklch(0.43 0.150 248 / 0.10); color: var(--primary); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; }
    .res-title { font-size: 17px; font-weight: 700; margin-bottom: 8px; line-height: 1.3; }
    .res-meta  { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
    .res-body  { font-size: 14px; color: var(--ink-2); line-height: 1.6; }
    .res-link  { display: inline-flex; align-items: center; gap: 5px; font-size: 13px; font-weight: 600; color: var(--primary); margin-top: 16px; transition: gap 180ms; }
    .res-link:hover { gap: 8px; }

    .research-b { background: var(--bg-2); }
    .res-b-grid { display: grid; grid-template-columns: 1fr 320px; gap: 40px; align-items: start; }
    .res-featured { background: var(--card); border: 1px solid var(--frame); border-radius: var(--radius); border-top: 3px solid var(--primary); padding: 40px; }
    .res-feat-tag   { margin-bottom: 16px; }
    .res-feat-title { font-size: 26px; font-weight: 800; line-height: 1.2; margin-bottom: 12px; }
    .res-feat-meta  { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
    .res-feat-body  { font-size: 15px; color: var(--ink-2); line-height: 1.7; }
    .res-sidebar    { display: flex; flex-direction: column; gap: 0; }
    .res-side-item  { padding: 18px 0; border-bottom: 1px solid var(--line); }
    .res-side-item:first-child { padding-top: 0; }
    .res-side-item:last-child  { border-bottom: none; }
    .rsi-tag   { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary); margin-bottom: 5px; }
    .rsi-title { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 3px; line-height: 1.3; }
    .rsi-meta  { font-size: 12px; color: var(--muted); }

    .research-c { background: var(--bg); }
    .res-c-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
    .res-tab { padding: 8px 18px; border-radius: 20px; font-size: 13px; font-weight: 700; border: 1.5px solid var(--line); color: var(--ink-2); cursor: pointer; background: var(--bg); transition: background 180ms, color 180ms, border-color 180ms; }
    .res-tab.active, .res-tab:hover { background: var(--primary); color: oklch(1 0 0); border-color: var(--primary); }
    .res-c-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .res-c-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; }
    .res-c-eye   { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 10px; }
    .res-c-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; line-height: 1.3; }
    .res-c-meta  { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
    .res-c-body  { font-size: 14px; color: var(--ink-2); line-height: 1.6; }

    @media (max-width: 1000px) {
      .plat-a-grid { grid-template-columns: 1fr; gap: 40px; }
      .plat-b-grid { grid-template-columns: 1fr; gap: 40px; }
      .live-panel  { position: static; }
      .plat-c-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
      .plat-kpi    { border-right: none; padding-right: 0; }
      .mdata-b-inner { grid-template-columns: 1fr; gap: 32px; }
      .res-b-grid  { grid-template-columns: 1fr; }
      .res-c-grid  { grid-template-columns: 1fr; }
    }
    @media (max-width: 700px) {
      .plat-features   { grid-template-columns: 1fr; }
      .mdata-a-grid    { grid-template-columns: 1fr; }
      .kpi-grid-4      { grid-template-columns: 1fr 1fr; }
      .research-grid-3 { grid-template-columns: 1fr; }
      .sparkline-row   { flex-direction: column; }
      .plat-c-grid     { grid-template-columns: 1fr; }
    }
  </style>

  <header class="page-header">
    <div class="page-header-inner">
      <span class="section-label">HNB Stockbrokers</span>
      <h1>Trade the CSE with research behind every decision</h1>
      <p class="page-header-sub">SEC registered stockbroker on the Colombo Stock Exchange. Online trading, live market data, and research-led advisory for private investors and institutions. Open a CDS account in 24 hours.</p>
      <div class="page-header-meta">
        <span class="pill">SEC Registered</span>
        <span class="pill">CSE Member</span>
        <span class="pill">CDS Account in 24hrs</span>
      </div>
    </div>
  </header>

  <div class="page-body">

    <!-- S1 Platform -->
    <section class="section-host" data-section-id="platform" data-section-label="Platform">

      <div class="variant section-wrap platform-a" data-variant="A">
        <div class="section-inner">
          <div class="section-header scroll-fade">
            <span class="section-label">Our Platform</span>
            <h2>Everything you need to trade Sri Lanka's equity market</h2>
          </div>
          <div class="plat-a-grid">
            <div class="plat-features scroll-fade">
              <div class="plat-feat">
                <div class="plat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.43 0.150 248)" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="8 21 12 17 16 21"/></svg></div>
                <div class="plat-title">Online Trading Platform</div>
                <p class="plat-body">Trade CSE-listed equities through our secure web and mobile platform. Real-time order placement, portfolio tracking, and transaction history.</p>
              </div>
              <div class="plat-feat">
                <div class="plat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.43 0.150 248)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
                <div class="plat-title">Research-Led Advisory</div>
                <p class="plat-body">Sector coverage from our research team. Stock recommendations backed by fundamental analysis. Weekly market wraps and earnings briefings.</p>
              </div>
              <div class="plat-feat">
                <div class="plat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.43 0.150 248)" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div>
                <div class="plat-title">Live Market Data</div>
                <p class="plat-body">Real-time ASPI and S&amp;P SL20 data, sector indices, market depth, and order book visibility for informed trading decisions.</p>
              </div>
              <div class="plat-feat">
                <div class="plat-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.43 0.150 248)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
                <div class="plat-title">Dedicated Advisory</div>
                <p class="plat-body">Named investment advisor assigned to every account. Portfolio review meetings. Access to HNB's broader financial network.</p>
              </div>
            </div>
            <div class="plat-stat-panel scroll-fade">
              <div class="stat-panel-heading">Today's CSE Snapshot</div>
              <div class="stat-row"><span class="stat-name">ASPI</span><span class="stat-val">22,622.34 <span class="stat-chg up">▲ 0.32%</span></span></div>
              <div class="stat-row"><span class="stat-name">S&amp;P SL20</span><span class="stat-val">6,225.28 <span class="stat-chg dn">▼ 0.12%</span></span></div>
              <div class="stat-row"><span class="stat-name">Share Volume</span><span class="stat-val">97.9M</span></div>
              <div class="stat-row"><span class="stat-name">Turnover</span><span class="stat-val">Rs. 2.15Bn</span></div>
              <div class="stat-row"><span class="stat-name">Listed Companies</span><span class="stat-val">296</span></div>
              <div class="plat-cta">
                <a href="/contact-us/" class="btn-primary" style="width:100%;justify-content:center;">Open a CDS Account</a>
                <p style="font-size:12px;color:var(--muted);margin-top:8px;">Approved in 24 hours</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="variant section-wrap platform-b" data-variant="B">
        <div class="section-inner">
          <div class="section-header scroll-fade">
            <span class="section-label">Our Platform</span>
            <h2>Built for Sri Lanka's equity market</h2>
          </div>
          <div class="plat-b-grid">
            <div class="feat-list scroll-fade">
              <div class="feat-item"><div class="feat-num">01</div><div><div class="feat-title">Online and mobile trading</div><p class="feat-desc">Place, modify, and cancel orders in real time through our web and mobile platform. Full transaction history and contract note download.</p></div></div>
              <div class="feat-item"><div class="feat-num">02</div><div><div class="feat-title">Research coverage</div><p class="feat-desc">Equity research across CSE sectors. Earnings notes, buy/sell recommendations, and sector briefings from our analyst team.</p></div></div>
              <div class="feat-item"><div class="feat-num">03</div><div><div class="feat-title">IPO and rights issue management</div><p class="feat-desc">Participation in CSE initial public offerings and rights issues through a single account. Allotments credited directly to your CDS.</p></div></div>
              <div class="feat-item"><div class="feat-num">04</div><div><div class="feat-title">Named investment advisor</div><p class="feat-desc">Every account is assigned a licensed investment advisor for portfolio review, market outlook discussions, and transaction support.</p></div></div>
            </div>
            <div class="live-panel scroll-fade">
              <div class="live-panel-head"><span class="live-panel-title">Live Indices</span><span class="live-label">Live</span></div>
              <div class="index-row"><div class="ir-name">All Share Price Index</div><div class="ir-val">22,622.34</div><div class="ir-chg up">▲ 71.84 (0.32%)</div></div>
              <div class="index-row"><div class="ir-name">S&amp;P SL20</div><div class="ir-val">6,225.28</div><div class="ir-chg dn">▼ 7.48 (0.12%)</div></div>
              <div class="sparkline-wrap-b sparkline-wrap" style="margin-top:20px;">
                <div class="ir-name" style="margin-bottom:8px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--primary);">ASPI — 30 Day</div>
                <svg class="sparkline-svg-b" viewBox="0 0 300 56" preserveAspectRatio="none">
                  <defs><linearGradient id="sg1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="oklch(0.43 0.150 248)" stop-opacity="0.20"/><stop offset="100%" stop-color="oklch(0.43 0.150 248)" stop-opacity="0"/></linearGradient></defs>
                  <path class="sparkline-area" d="M0,48 L25,42 L50,38 L75,44 L100,36 L125,28 L150,32 L175,22 L200,18 L225,24 L250,16 L275,10 L300,8 L300,56 L0,56 Z" fill="url(#sg1)"/>
                  <path class="sparkline-path" d="M0,48 L25,42 L50,38 L75,44 L100,36 L125,28 L150,32 L175,22 L200,18 L225,24 L250,16 L275,10 L300,8" fill="none" stroke="oklch(0.43 0.150 248)" stroke-width="1.5"/>
                </svg>
              </div>
              <a href="/contact-us/" class="btn-primary" style="width:100%;justify-content:center;margin-top:20px;">Open a CDS Account</a>
            </div>
          </div>
        </div>
      </div>

      <div class="variant section-wrap platform-c" data-variant="C">
        <div class="section-inner">
          <div class="plat-c-top scroll-fade">
            <span class="section-label">Our Platform</span>
            <h2>Sri Lanka's equity market — live, in your hands</h2>
            <p style="margin-top:12px;font-size:16px;">HNB Stockbrokers gives you SEC-regulated access to all 296 CSE-listed companies, backed by research and a named advisor.</p>
          </div>
          <div class="plat-c-grid scroll-fade">
