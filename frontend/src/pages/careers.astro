---
import InnerLayout from '../layouts/InnerLayout.astro';

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;
const STRAPI_TOKEN = import.meta.env.STRAPI_TOKEN;
let jobs: any[] = [];
try {
  const headers: Record<string, string> = {};
  if (STRAPI_TOKEN) headers['Authorization'] = `Bearer ${STRAPI_TOKEN}`;
  const res = await fetch(`${STRAPI_URL}/api/jobs?sort=publishedAt:desc`, { headers });
  if (res.ok) {
    const json = await res.json();
    jobs = json.data || [];
  }
} catch {}

function attr(j: any, key: string, fallback = '') {
  return j?.attributes?.[key] ?? fallback;
}
const hasJobs = jobs.length > 0;
---

<InnerLayout title="Careers — HNB Investment Bank" active="careers">
  <style is:global>
    /* ── Open Positions ──────────────────────────── */
    .jobs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .job-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.5rem; display: flex; flex-direction: column; }
    .job-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; gap: 0.75rem; }
    .job-dept { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); background: oklch(0.43 0.150 248 / 0.08); border: 1px solid oklch(0.43 0.150 248 / 0.15); border-radius: 4px; padding: 0.2rem 0.6rem; }
    .job-type { font-size: 0.72rem; color: var(--muted); background: var(--bg-2); border: 1px solid var(--line); border-radius: 4px; padding: 0.2rem 0.6rem; white-space: nowrap; }
    .job-card h4 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 0.375rem; }
    .job-card .job-location { font-size: 0.8rem; color: var(--muted); margin-bottom: 0.75rem; }
    .job-card p { font-size: 0.82rem; color: var(--ink-2); line-height: 1.65; flex: 1; margin-bottom: 1rem; }
    .job-apply { font-size: 0.82rem; font-weight: 700; color: var(--primary); text-decoration: none; }
    .jobs-b-layout { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; align-items: start; }
    .dept-filter { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
    .dept-filter h4 { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); padding: 1rem 1.25rem; border-bottom: 1px solid var(--line); }
    .dept-filter a { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--line); font-size: 0.875rem; color: var(--ink-2); text-decoration: none; }
    .dept-filter a:last-child { border-bottom: none; }
    .dept-filter a:hover, .dept-filter a.active { color: var(--primary); background: oklch(0.43 0.150 248 / 0.04); }
    .dept-filter .dcnt { font-size: 0.75rem; color: var(--muted); }
    .job-list-full { display: flex; flex-direction: column; gap: 0.875rem; }
    .job-list-item { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.25rem 1.5rem; display: flex; align-items: center; gap: 1.25rem; }
    .jli-info { flex: 1; }
    .jli-info h4 { font-size: 0.925rem; font-weight: 700; color: var(--ink); margin-bottom: 0.25rem; }
    .jli-meta { display: flex; gap: 0.75rem; font-size: 0.78rem; color: var(--muted); }
    .jli-dept { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); background: oklch(0.43 0.150 248 / 0.08); border: 1px solid oklch(0.43 0.150 248 / 0.15); border-radius: 4px; padding: 0.2rem 0.5rem; flex-shrink: 0; }
    .jobs-c-featured { background: var(--primary); border-radius: var(--radius); padding: 3rem; color: #fff; margin-bottom: 1.5rem; }
    .jobs-c-featured .section-label { color: oklch(0.65 0.165 140); }
    .jobs-c-featured h2 { color: #fff; margin: 0.75rem 0 1rem; }
    .jobs-c-featured p { color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 1.5rem; }
    .jobs-c-count { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.2); }
    .jcc-item .jcc-val { font-size: 1.75rem; font-weight: 800; color: #fff; }
    .jcc-item .jcc-label { font-size: 0.75rem; color: rgba(255,255,255,0.65); }
    /* ── Culture & Values ───────────────────────── */
    .culture-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .culture-card { background: var(--card); border: 1px solid var(--line); border-left: 3px solid var(--accent); border-radius: var(--radius); padding: 1.75rem; }
    .culture-card .cc-icon { font-size: 1.75rem; margin-bottom: 0.875rem; }
    .culture-card h4 { font-size: 0.95rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; }
    .culture-card p { font-size: 0.83rem; color: var(--ink-2); line-height: 1.65; margin: 0; }
    .culture-b-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
    .culture-b-copy h3 { font-size: 1.25rem; font-weight: 800; color: var(--ink); margin-bottom: 1rem; }
    .culture-b-copy p { font-size: 0.875rem; color: var(--ink-2); line-height: 1.7; margin-bottom: 1rem; }
    .benefits-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .benefit-item { display: flex; gap: 0.875rem; align-items: flex-start; }
    .bi-icon { width: 32px; height: 32px; border-radius: 8px; background: oklch(0.43 0.150 248 / 0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .bi-icon svg { width: 16px; height: 16px; stroke: var(--primary); fill: none; }
    .bi-body h5 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.1rem; }
    .bi-body p { font-size: 0.8rem; color: var(--ink-2); line-height: 1.5; margin: 0; }
    .culture-c-inner { background: var(--primary); border-radius: var(--radius); padding: 3rem; color: #fff; }
    .culture-c-inner .section-label { color: oklch(0.65 0.165 140); }
    .culture-c-inner h2 { color: #fff; margin: 0.75rem 0 1rem; }
    .culture-c-inner > p { color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 1.5rem; }
    .culture-c-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .culture-c-tile { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: var(--radius); padding: 1.5rem; }
    .culture-c-tile h4 { font-size: 0.925rem; font-weight: 700; color: #fff; margin-bottom: 0.375rem; }
    .culture-c-tile p { font-size: 0.8rem; color: rgba(255,255,255,0.65); line-height: 1.55; margin: 0; }
    /* ── How to Apply ─────────────────────────── */
    .apply-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative; }
    .apply-steps::before { content: ''; position: absolute; top: 28px; left: 12.5%; right: 12.5%; height: 2px; background: var(--line); z-index: 0; }
    .apply-step { text-align: center; position: relative; z-index: 1; padding: 0 1rem; }
    .as-circle { width: 56px; height: 56px; border-radius: 50%; background: var(--bg); border: 2px solid var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.1rem; font-weight: 800; color: var(--primary); }
    .apply-step h4 { font-size: 0.875rem; font-weight: 700; color: var(--ink); margin-bottom: 0.375rem; }
    .apply-step p { font-size: 0.78rem; color: var(--ink-2); line-height: 1.55; }
    .apply-b-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
    .apply-b-copy h3 { font-size: 1.1rem; font-weight: 700; color: var(--ink); margin-bottom: 0.875rem; }
    .apply-b-copy p { font-size: 0.875rem; color: var(--ink-2); line-height: 1.7; margin-bottom: 1rem; }
    .apply-b-copy .tips-list { list-style: none; padding: 0; }
    .apply-b-copy .tips-list li { font-size: 0.82rem; color: var(--ink-2); padding: 0.375rem 0; border-bottom: 1px solid var(--line); display: flex; gap: 0.5rem; }
    .apply-b-copy .tips-list li::before { content: '→'; color: var(--primary); }
    .apply-b-copy .tips-list li:last-child { border-bottom: none; }

    @media (max-width: 960px) {
      .jobs-b-layout { grid-template-columns: 1fr; }
      .culture-b-grid, .apply-b-grid { grid-template-columns: 1fr; }
      .apply-steps { grid-template-columns: 1fr 1fr; }
      .apply-steps::before { display: none; }
      .culture-c-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .jobs-grid, .culture-grid, .culture-c-grid, .jobs-c-count { grid-template-columns: 1fr; }
      .apply-steps { grid-template-columns: 1fr; }
    }
  </style>

  <header class="page-header">
    <div class="page-header-inner">
      <span class="section-label">Company</span>
      <h1>Build Your Career in Sri Lankan Capital Markets</h1>
      <p class="page-header-sub">HNB Investment Bank offers careers across equity dealing, fixed income, M&amp;A advisory, venture investing, and operations — in Sri Lanka's most active integrated investment bank.</p>
      <div class="page-header-meta">
        <span class="pill-accent">12 Open Positions</span>
        <span class="pill">Colombo, Sri Lanka</span>
        <span class="pill">Immediate &amp; Planned Hiring</span>
      </div>
    </div>
  </header>

  <div class="page-body">
    <div class="page-bg-map" aria-hidden="true"></div>

    <!-- ══ S1: OPEN POSITIONS ══ -->
    <section class="section-host" id="open-positions" data-section-id="open-positions" data-section-label="Open Positions">

      <!-- VARIANT A: 2-col job cards -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Open Positions</span>
              <h2>{hasJobs ? `${jobs.length} Current Openings` : '12 Current Openings'}</h2>
              <p>Roles spanning all four business lines. Most positions are based in our Colombo headquarters at No. 479, T B Jayah Mawatha, Colombo 10.</p>
            </div>
            <div class="jobs-grid">
              {hasJobs ? jobs.map((j: any) => (
                <div class="job-card">
                  <div class="job-card-top"><span class="job-dept">{attr(j, 'department', 'General')}</span><span class="job-type">{attr(j, 'type', 'Full-time')}</span></div>
                  <h4>{attr(j, 'title')}</h4>
                  <div class="job-location">📍 {attr(j, 'location', 'Colombo 10')} · {attr(j, 'timing', 'Immediate')}</div>
                  <p>{attr(j, 'description')}</p>
                  <a href="#apply" class="job-apply">Apply now →</a>
                </div>
              )) : (<>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Equity Dealing</span><span class="job-type">Full-time</span></div><h4>Equity Dealer — CSE</h4><div class="job-location">📍 Colombo 10 · Immediate</div><p>Execute CSE equity transactions for institutional and high-net-worth clients. Requires SLCFMA dealing licence and minimum 2 years CSE dealing experience.</p><a href="#apply" class="job-apply">Apply now →</a></div>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Corporate Finance</span><span class="job-type">Full-time</span></div><h4>Associate — M&amp;A Advisory</h4><div class="job-location">📍 Colombo 10 · Immediate</div><p>Execution of M&A advisory mandates including valuation, information memoranda, and investor outreach. 2–3 years IB or Big 4 transaction services background required.</p><a href="#apply" class="job-apply">Apply now →</a></div>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Fixed Income</span><span class="job-type">Full-time</span></div><h4>Fixed Income Analyst</h4><div class="job-location">📍 Colombo 10 · Immediate</div><p>Analysis of government securities market, yield curve modelling, client Repo portfolio management, and support for the Primary Dealer function. CFA Level I candidate preferred.</p><a href="#apply" class="job-apply">Apply now →</a></div>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Research</span><span class="job-type">Full-time</span></div><h4>Equity Research Analyst</h4><div class="job-location">📍 Colombo 10 · Q3 2025</div><p>Coverage of 6–8 CSE-listed companies across financials and industrials sectors. Initiating coverage notes, quarterly earnings updates, and client presentations.</p><a href="#apply" class="job-apply">Apply now →</a></div>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Venture Capital</span><span class="job-type">Full-time</span></div><h4>Investment Associate — LVL</h4><div class="job-location">📍 Colombo 10 · Q3 2025</div><p>Deal sourcing, due diligence, and portfolio company monitoring for LVL Energy Fund and co-investment vehicles. Experience in PE/VC or corporate development preferred.</p><a href="#apply" class="job-apply">Apply now →</a></div>
                <div class="job-card"><div class="job-card-top"><span class="job-dept">Technology</span><span class="job-type">Full-time</span></div><h4>Software Engineer — Trading Systems</h4><div class="job-location">📍 Colombo 10 · Immediate</div><p>Build and maintain the HNB Stockbrokers trading platform. React front-end, Node.js backend, real-time CSE data feeds. 3+ years full-stack experience required.</p><a href="#apply" class="job-apply">Apply now →</a></div>
              </>)}
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT B: Dept filter + list -->
      <div class="variant" data-variant="B" data-variant-label="Middle">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Open Positions</span>
              <h2>Browse All 12 Openings</h2>
            </div>
            <div class="jobs-b-layout">
              <div>
                <nav class="dept-filter" aria-label="Department filter">
                  <h4>Department</h4>
                  <a href="#" class="active" data-dept="all">All Departments <span class="dcnt">12</span></a>
                  <a href="#" data-dept="equity">Equity Dealing <span class="dcnt">3</span></a>
                  <a href="#" data-dept="corp-finance">Corporate Finance <span class="dcnt">2</span></a>
                  <a href="#" data-dept="fixed-income">Fixed Income <span class="dcnt">2</span></a>
                  <a href="#" data-dept="research">Research <span class="dcnt">2</span></a>
                  <a href="#" data-dept="venture-capital">Venture Capital <span class="dcnt">1</span></a>
                  <a href="#" data-dept="technology">Technology <span class="dcnt">2</span></a>
                </nav>
              </div>
              <div class="job-list-full">
                <div class="job-list-item" data-dept="equity"><div class="jli-info"><h4>Equity Dealer — CSE</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Immediate</span></div></div><span class="jli-dept">Equity</span></div>
                <div class="job-list-item" data-dept="corp-finance"><div class="jli-info"><h4>Associate — M&amp;A Advisory</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Immediate</span></div></div><span class="jli-dept">Corp. Finance</span></div>
                <div class="job-list-item" data-dept="fixed-income"><div class="jli-info"><h4>Fixed Income Analyst</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Immediate</span></div></div><span class="jli-dept">Fixed Income</span></div>
                <div class="job-list-item" data-dept="research"><div class="jli-info"><h4>Equity Research Analyst</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Q3 2025</span></div></div><span class="jli-dept">Research</span></div>
                <div class="job-list-item" data-dept="venture-capital"><div class="jli-info"><h4>Investment Associate — LVL</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Q3 2025</span></div></div><span class="jli-dept">Venture Capital</span></div>
                <div class="job-list-item" data-dept="technology"><div class="jli-info"><h4>Software Engineer — Trading Systems</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Immediate</span></div></div><span class="jli-dept">Technology</span></div>
                <div class="job-list-item" data-dept="compliance"><div class="jli-info"><h4>Compliance Officer</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Immediate</span></div></div><span class="jli-dept">Compliance</span></div>
                <div class="job-list-item" data-dept="equity"><div class="jli-info"><h4>Institutional Sales — Equities</h4><div class="jli-meta"><span>Colombo 10</span><span>·</span><span>Full-time</span><span>·</span><span>Q4 2025</span></div></div><span class="jli-dept">Equity</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT C: Editorial header + grid -->
      <div class="variant" data-variant="C" data-variant-label="Ambitious">
        <div class="section-wrap scroll-fade">
          <div class="section-inner">
            <div class="jobs-c-featured">
              <span class="section-label">Open Positions</span>
              <h2>Where Capital Markets Careers Are Built</h2>
              <p>We hire people who are serious about Sri Lanka's financial markets — not people marking time on their way somewhere else. Every open role is a real position on a team that moves material capital.</p>
              <div class="jobs-c-count">
                <div class="jcc-item"><div class="jcc-val">12</div><div class="jcc-label">Open Positions</div></div>
                <div class="jcc-item"><div class="jcc-val">4</div><div class="jcc-label">Business Lines</div></div>
                <div class="jcc-item"><div class="jcc-val">7</div><div class="jcc-label">Immediate Starts</div></div>
                <div class="jcc-item"><div class="jcc-val">LKR</div><div class="jcc-label">Market-Rate Compensation</div></div>
              </div>
            </div>
            <div class="jobs-grid">
              <div class="job-card"><div class="job-card-top"><span class="job-dept">Equity Dealing</span><span class="job-type">Immediate</span></div><h4>Equity Dealer — CSE</h4><div class="job-location">📍 Colombo 10</div><p>Execute institutional and HNW equity transactions. SLCFMA licence required.</p><a href="#apply" class="job-apply">Apply →</a></div>
              <div class="job-card"><div class="job-card-top"><span class="job-dept">Corporate Finance</span><span class="job-type">Immediate</span></div><h4>Associate — M&amp;A Advisory</h4><div class="job-location">📍 Colombo 10</div><p>M&A execution: valuation, IMs, investor outreach. 2–3 years IB background.</p><a href="#apply" class="job-apply">Apply →</a></div>
              <div class="job-card"><div class="job-card-top"><span class="job-dept">Fixed Income</span><span class="job-type">Immediate</span></div><h4>Fixed Income Analyst</h4><div class="job-location">📍 Colombo 10</div><p>Yield curve modelling, Repo portfolio management, Primary Dealer support.</p><a href="#apply" class="job-apply">Apply →</a></div>
              <div class="job-card"><div class="job-card-top"><span class="job-dept">Technology</span><span class="job-type">Immediate</span></div><h4>Software Engineer — Trading Systems</h4><div class="job-location">📍 Colombo 10</div><p>React / Node.js trading platform. Real-time CSE data integration.</p><a href="#apply" class="job-apply">Apply →</a></div>
            </div>
            <div style="text-align:center; margin-top:1.5rem;"><a href="#apply" class="btn-primary">View All 12 Positions</a></div>
          </div>
        </div>
      </div>

    </section>

    <!-- ══ S2: CULTURE & VALUES ══ -->
    <section class="section-host" data-section-id="culture-values" data-section-label="Culture &amp; Values">

      <!-- VARIANT A: 3-col cards -->
      <div class="variant" data-variant="A" data-variant-label="Simple">
        <div class="section-wrap scroll-fade" style="background:var(--bg-2);">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Culture &amp; Values</span>
              <h2>What Working Here Is Actually Like</h2>
              <p>We're not going to tell you we have a ping-pong table. Here's what actually matters in this building.</p>
            </div>
            <div class="culture-grid">
              <div class="culture-card"><div class="cc-icon">📊</div><h4>Real Work from Day One</h4><p>Analysts run models and attend client calls from their first month. We don't warehouse junior staff in back-office tasks until someone retires.</p></div>
              <div class="culture-card"><div class="cc-icon">🏆</div><h4>Meritocratic Advancement</h4><p>Promotions are based on deal contribution and client outcomes — not tenure. We've had analysts promoted to Associate in under 18 months.</p></div>
              <div class="culture-card"><div class="cc-icon">🌏</div><h4>Sri Lanka Focused</h4><p>Our edge is deep knowledge of Sri Lankan corporates, regulators, and capital markets. We hire people who want to be the best in this market — not the ones passing through.</p></div>
              <div class="culture-card"><div class="cc-icon">📚</div><h4>CFA &amp; Professional Support</h4><p>HNB Investment Bank covers 100% of CFA exam fees, provides study leave, and maintains a CFA study programme for enrolled employees.</p></div>
              <div class="culture-card"><div class="cc-icon">⚖️</div><h4>Ethical Practice</h4><p>In a market where corners get cut, we don't. Our compliance culture is strict, our track record is clean, and our clients notice the difference.</p></div>
              <div class="culture-card"><div class="cc-icon">💰</div><h4>Competitive Compensation</h4><p>Base salaries benchmarked to market median. Variable pay tied to team and individual performance. Annual review cycle with transparent criteria.</p></div>
            </div>
          </div>
        </div>
      </div>

      <!-- VARIANT B: Two-col with benefits -->
      <div class="variant" data-variant="B" data-variant-label="Middle">
        <div class="section-wrap scroll-fade" style="background:var(--bg-2);">
          <div class="section-inner">
            <div class="section-header">
              <span class="section-label">Culture &amp; Values</span>
              <h2>An Environment Where Expertise Is Valued</h2>
            </div>
            <div class="culture-b-grid">
              <div class="culture-b-copy">
                <h3>We hire for depth, not credentials</h3>
                <p>We care more about whether you understand Sri Lanka's T-Bill yield curve than whether you went to a particular school. Our best analysts have come from everywhere from IIT to the University of Kelaniya — what they share is intellectual rigour and genuine curiosity about markets.</p>
                <p>The team is small enough that everyone's contribution is visible. You will not spend years being invisible in a hierarchy of 10,000 people.</p>
                <div style="margin-top:1.25rem; display:flex; gap:1rem; flex-wrap:wrap;">
                  <a href="#open-positions" class="btn-primary">View Open Positions</a>
                </div>
              </div>
              <div>
                <div style="font-size:0.875rem; font-weight:700; color:var(--ink); margin-bottom:1rem;">Benefits &amp; Support</div>
                <div class="benefits-list">
