---
import Layout from '../layouts/Layout.astro';

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL || '';
const STRAPI_TOKEN = import.meta.env.STRAPI_TOKEN || '';

let articles: any[] = [];
if (STRAPI_URL) {
  try {
    const headers: Record<string, string> = { 'Content-Type': 'application/json' };
    if (STRAPI_TOKEN) headers['Authorization'] = `Bearer ${STRAPI_TOKEN}`;
    const res = await fetch(
      `${STRAPI_URL}/api/articles?populate=coverImage&sort[0]=publishedDate:desc&pagination[pageSize]=3`,
      { headers }
    );
    if (res.ok) {
      const data = await res.json();
      articles = data.data || [];
    }
  } catch (_) {
    /* fall through to static placeholders */
  }
}

const staticArticles = [
  {
    title: 'Empowering your progress with bespoke investment solutions',
    category: 'Capital Markets',
    excerpt: 'How HNB Investment Bank is driving the evolution of Sri Lanka\'s capital markets through personalised mandates.',
    meta: '3 min · May 2025',
    href: '/news/',
  },
  {
    title: 'Singer Finance LKR 2Bn subordinated debt trust certificate — full subscription',
    category: 'Debt Capital Markets',
    excerpt: 'HNBIB and Serendib Frontier Capital spearhead the full subscription of Singer Finance\'s debt offering.',
    meta: '4 min · Apr 2025',
    href: '/news/',
  },
  {
    title: 'HNB Investment Bank extends CFA Society Sri Lanka partnership as Silver Partner',
    category: 'Industry',
    excerpt: 'Continuing our commitment to raising the standard of investment analysis and portfolio management in Sri Lanka.',
    meta: '2 min · Mar 2025',
    href: '/news/',
  },
];

const displayArticles = articles.length >= 3
  ? articles.slice(0, 3).map((a: any) => ({
      title: a.attributes?.title || a.title || '',
      category: a.attributes?.category || a.category || 'News',
      excerpt: a.attributes?.excerpt || a.excerpt || '',
      meta: a.attributes?.publishedDate
        ? new Date(a.attributes.publishedDate).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })
        : '',
      href: `/news/${a.attributes?.slug || a.slug || ''}`,
    }))
  : staticArticles;
